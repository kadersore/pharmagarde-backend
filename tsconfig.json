{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["./shared/*"]
    },
    "outDir": "dist"
  },
  "include": ["server/**/*.ts", "drizzle/**/*.ts", "shared/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}
